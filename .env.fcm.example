# FCM (Firebase Cloud Messaging) Configuration
# Add these to your .env file

# Enable/Disable FCM notifications
FCM_ENABLED=true

# Batch processing
FCM_BATCH_SIZE=500

# Retry configuration
FCM_RETRY_ATTEMPTS=3
FCM_RETRY_DELAY=10

# Time to live for messages (in seconds)
# 86400 = 24 hours, 3600 = 1 hour
FCM_DEFAULT_TTL=86400

# Message priority
FCM_PRIORITY=high

# Days before considering a token stale (inactive)
FCM_STALE_TOKEN_DAYS=30

# Firebase credentials path (relative to storage/app)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Firebase project information (optional, extracted from credentials)
FIREBASE_PROJECT_ID=your-project-id

# Firebase database URL (optional)
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Queue configuration
# Use 'notifications' queue for FCM jobs (recommended)
QUEUE_CONNECTION=database

# For better performance, use Redis queue
# QUEUE_CONNECTION=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
